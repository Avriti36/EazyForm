{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "lint": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "outputs": ["apps/server/drizzle/**"]
    },
    "db:push": {
      "cache": false,
      "outputs": ["apps/server/drizzle/**"]
    },
    "db:studio": {
      "cache": false
    }
  }
}
