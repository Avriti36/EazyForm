{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["bun-types"],
    "paths": {
      "@/*": ["./src/*"],
      "@formly/shared": ["../../packages/shared/types/form-schema.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
