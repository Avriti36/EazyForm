# ============================================
# FORMLY — Server Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# ============================================
# STORAGE MODE
# ============================================
# Choose storage backend: "local" or "s3"
STORAGE_MODE=local

# ────────────────────────────────────────────
# LOCAL STORAGE (default for local dev)
# ────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

# ────────────────────────────────────────────
# S3 STORAGE (production / self-hosted)
# Only needed if STORAGE_MODE=s3
# ────────────────────────────────────────────
# AWS credentials (use IAM roles in production, not access keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=formly-uploads
# Optional: custom S3 endpoint (for MinIO, Backblaze, etc.)
# AWS_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com

# ============================================
# AUTHENTICATION
# ============================================
# NextAuth.js v5 session secret (auto-generated if blank)
AUTH_SECRET=
# NextAuth URL (must match your app URL)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
DATABASE_URL=postgresql://formly:password@localhost:5432/formly

# ============================================
# AI — MiniMax M2.7 via Anthropic SDK
# ============================================
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# ============================================
# STRIPE — Payments & Subscriptions
# ============================================
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ============================================
# APP URLs
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# ============================================
# EMAIL — Resend (optional)
# ============================================
RESEND_API_KEY=
