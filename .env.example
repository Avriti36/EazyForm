# ============================================
# FORMLY — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# Values shown with = are defaults — safe to leave as-is for local dev.

# ============================================
# STORAGE MODE
# ============================================
# Choose storage backend: "local" or "s3"
STORAGE_MODE=local

# ────────────────────────────────────────────
# LOCAL STORAGE (default for local dev)
# ────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

# ────────────────────────────────────────────
# S3 STORAGE (production / self-hosted)
# Only needed if STORAGE_MODE=s3
# ────────────────────────────────────────────
# AWS credentials (use IAM roles in production, not access keys)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=formly-uploads
# Optional: custom S3 endpoint (for MinIO, Backblaze, etc.)
# AWS_S3_ENDPOINT=https://s3.us-east-1.amazonaws.com

# ============================================
# AUTHENTICATION
# ============================================
# better-auth session secret (auto-generated if blank)
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
# For Docker: postgresql://formly:password@localhost:5432/formly
# For Neon/Supabase: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql://formly:password@localhost:5432/formly

# ============================================
# AI — MiniMax M2.7 via Anthropic SDK
# ============================================
# Get from https://platform.minimax.io/subscribe/token-plan
# Your API key is exclusive to Token Plan — not interchangeable with pay-as-you-go keys
ANTHROPIC_API_KEY=
# MiniMax Anthropic-compatible endpoint (use this exact URL)
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic

# ============================================
# STRIPE — Payments & Subscriptions
# ============================================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Create a $12/month Pro plan product in Stripe Dashboard
STRIPE_PRO_PRICE_ID=

# ============================================
# APP URLs
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# ============================================
# EMAIL — Resend (optional, for form submission notifications)
# ============================================
# Get from https://resend.com
RESEND_API_KEY=
