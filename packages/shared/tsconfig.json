{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": false,
    "declaration": true,
    "outDir": "./dist"
  },
  "include": ["types/**/*", "utils/**/*"],
  "exclude": ["node_modules"]
}
